# SideNote2 DGX bridge example environment
# Local development defaults to loopback HTTP.
# For mobile or VPN access, point SIDENOTE2_DGX_PUBLIC_BASE_URL at a reachable HTTPS URL
# and either terminate TLS in a reverse proxy or configure the TLS file paths below.

SIDENOTE2_DGX_BIND_HOST=127.0.0.1
SIDENOTE2_DGX_PORT=4215
SIDENOTE2_DGX_PUBLIC_BASE_URL=http://127.0.0.1:4215
# SIDENOTE2_DGX_PUBLIC_BASE_URL=https://dgx.example.internal:4215
SIDENOTE2_DGX_WORKSPACE_ROOT=.dgx-workspace
# Required for workspace-aware-vault runs from mobile/shared-vault clients.
# This must point at the synced vault copy the DGX is allowed to inspect and edit.
# SIDENOTE2_DGX_VAULT_ROOT=/absolute/path/to/synced-vault
# SIDENOTE2_DGX_TLS_CERT_FILE=/absolute/path/to/bridge-cert.pem
# SIDENOTE2_DGX_TLS_KEY_FILE=/absolute/path/to/bridge-key.pem
# SIDENOTE2_DGX_TLS_CA_FILE=/absolute/path/to/ca-chain.pem

# Bridge authentication
SIDENOTE2_DGX_BRIDGE_BEARER_TOKEN=replace-with-a-long-random-token

# Access and allowance
# Future option if we later support non-token allowance identities:
# SIDENOTE2_DGX_ALLOWANCE_IDENTITY_MODE=bridge_token
SIDENOTE2_DGX_FREE_ALLOWANCE_ENABLED=true
SIDENOTE2_DGX_FREE_ALLOWANCE_RUNS_PER_DAY=50

# Codex runtime
SIDENOTE2_DGX_CODEX_BIN=codex
